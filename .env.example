# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for minting Supabase-compatible sessions after SIWE
SUPABASE_JWT_SECRET=

# Web3 / Wallets
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_CONTRACT_SUBSCRIPTION=
NEXT_PUBLIC_CONTRACT_PAYMENT=
NEXT_PUBLIC_USDC_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# RPC
# NEXT_PUBLIC_CHAIN_ID selecciona la red en el frontend y en las API routes
# (137 = Polygon mainnet, 80001 = Mumbai testnet) vía lib/chain.ts.
NEXT_PUBLIC_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Edge Functions (Deno) — espejo de las variables anteriores en Supabase secrets.
# CHAIN_ID selecciona la red en confirm-transaction (137 / 80001).
CHAIN_ID=137
# Secreto para firmar webhooks salientes (HMAC-SHA256). Configurar como secret de
# las Edge Functions process-webhook / retry-webhooks. Sin él, process-webhook
# aborta (fallo cerrado): no se firma ningún webhook con un secreto por defecto.
WEBHOOK_SIGNING_SECRET=

# Deploy (never expose in frontend)
PRIVATE_KEY_DEPLOYER=
POLYGONSCAN_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email transaccional (opcional). Sin RESEND_API_KEY las notificaciones por email
# se omiten silenciosamente (fallo abierto: no rompen pagos ni revocaciones).
RESEND_API_KEY=
EMAIL_FROM=Contenline <noreply@contenline.app>
